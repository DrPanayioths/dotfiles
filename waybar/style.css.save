* {
    font-family: "JetBrains Mono", sans-serif;
    font-size: 12px;
    color: white;
}

window#waybar {
    background: transparent;
}

#workspaces button {
    padding: 2px 10px;
    margin: 4px 2px;
    border-radius: 20px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.3);
    color: white;
}

#workspaces button.active {
    border: 1px solid rgba(255,255,255,0.9);
}

#clock, #cpu, #memory, #network, #pulseaudio {
    margin: 4px 4px;
    border-radius: 10px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.3);
}



